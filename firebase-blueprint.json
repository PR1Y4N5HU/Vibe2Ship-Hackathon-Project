{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User preferences, work hours, and emergency pass stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase user ID" },
        "email": { "type": "string", "description": "User email address" },
        "workStart": { "type": "string", "description": "Work hour start time (HH:MM)" },
        "workEnd": { "type": "string", "description": "Work hour end time (HH:MM)" },
        "freeStart": { "type": "string", "description": "Free time start time (HH:MM)" },
        "freeEnd": { "type": "string", "description": "Free time end time (HH:MM)" },
        "emergencyPassesUsed": { "type": "number", "description": "Number of emergency passes used in current task cycle" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["uid", "email", "workStart", "workEnd", "freeStart", "freeEnd", "emergencyPassesUsed"]
    },
    "Task": {
      "title": "Task",
      "description": "A task with decomposed steps, schedules, and reinforcement text",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Task identifier" },
        "userId": { "type": "string", "description": "Owner user ID" },
        "title": { "type": "string", "description": "Task title" },
        "description": { "type": "string", "description": "Task description" },
        "deadline": { "type": "string", "format": "date-time", "description": "Task deadline" },
        "importance": { "type": "string", "enum": ["low", "medium", "high"], "description": "Urgency rating" },
        "userPreference": { "type": "string", "enum": ["low", "medium", "high"], "description": "User priority preference" },
        "isPrimary": { "type": "boolean", "description": "Is this the single active focus task?" },
        "workHoursOption": { "type": "string", "enum": ["free", "both"], "description": "Schedule option" },
        "reinforcementTyped": { "type": "string", "description": "Cognitive reinforcement text typed by the user" },
        "status": { "type": "string", "enum": ["pending", "reinforcing", "active", "completed"], "description": "Current execution status" },
        "steps": {
          "type": "array",
          "description": "Decomposed task steps generated by AI"
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["id", "userId", "title", "description", "deadline", "importance", "userPreference", "isPrimary", "workHoursOption", "status", "steps"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Root collection for user profiles"
    },
    "tasks/{taskId}": {
      "schema": "Task",
      "description": "Root collection for all user tasks"
    }
  }
}
